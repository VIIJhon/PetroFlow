# API Configuration
REACT_APP_API_URL=http://localhost:8000
REACT_APP_WS_URL=ws://localhost:8000/ws

# MQTT Configuration (if using direct MQTT from frontend)
REACT_APP_MQTT_BROKER=ws://localhost:9001
REACT_APP_MQTT_USERNAME=
REACT_APP_MQTT_PASSWORD=

# Feature Flags
REACT_APP_ENABLE_3D_VIEWER=true
REACT_APP_ENABLE_ANALYTICS=true
REACT_APP_ENABLE_SIMULATION=true

# Authentication
REACT_APP_TOKEN_REFRESH_INTERVAL=840000
REACT_APP_SESSION_TIMEOUT=3600000

# Environment
REACT_APP_ENV=development

# Logging
REACT_APP_LOG_LEVEL=debug

# Chart.js Configuration
REACT_APP_CHART_ANIMATION=true
REACT_APP_MAX_CHART_POINTS=1000

# WebSocket Configuration
REACT_APP_WS_RECONNECT_INTERVAL=5000
REACT_APP_WS_MAX_RECONNECT_ATTEMPTS=10

# Pagination
REACT_APP_DEFAULT_PAGE_SIZE=20
REACT_APP_MAX_PAGE_SIZE=100